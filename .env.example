# Get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model selection (pick one):
#   gemini-2.5-flash-preview-05-20   — fast, cheaper, good for most pages
#   gemini-2.5-pro-preview-05-06     — slower, more accurate for complex UIs
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# Temperature — keep low for deterministic analysis
GEMINI_TEMPERATURE=0.1

# Max image dimension sent to Gemini (pixels, longest side)
MAX_IMAGE_DIM=2048
